FROM ruby:3.4.7-slim

ARG DEBIAN_CODENAME=trixie

ENV COVERAGE=true \
    DEBIAN_FRONTEND=noninteractive

RUN apt-get update -y || (echo "Host mirrors failed, trying default Debian mirrors..." && \
    echo "deb http://deb.debian.org/debian ${DEBIAN_CODENAME} main contrib non-free" > /etc/apt/sources.list && \
    echo "deb http://deb.debian.org/debian ${DEBIAN_CODENAME}-updates main contrib non-free" >> /etc/apt/sources.list && \
    echo "deb http://deb.debian.org/debian-security ${DEBIAN_CODENAME}-security main contrib non-free" >> /etc/apt/sources.list && \
    apt-get update -y) || (echo "Default Debian mirrors failed, trying mirror list from deb.debian.org..." && \
    echo "deb mirror://mirrors.debian.org/mirror.txt ${DEBIAN_CODENAME} main contrib non-free" > /etc/apt/sources.list && \
    echo "deb mirror://mirrors.debian.org/mirror.txt ${DEBIAN_CODENAME}-updates main contrib non-free" >> /etc/apt/sources.list && \
    echo "deb mirror://mirrors.debian.org/mirror.txt ${DEBIAN_CODENAME}-security main contrib non-free" >> /etc/apt/sources.list && \
    apt-get update -y)

RUN apt-get install -y --no-install-recommends \
    jq \
    shunit2 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

RUN gem install --no-document \
    bashcov \
    simplecov:0.22.0 \
    simplecov-cobertura:2.1.0

USER 1001
WORKDIR /conjur-action
COPY . .